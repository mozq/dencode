		<tr><th>Yunanca</th><td><b>Π</b></td><td><b>τ</b></td><td><b>ο</b></td><td><b>λ</b></td><td>ε</td><td>μ</td><td>α</td><td>ῖ</td><td>ο</td><td>ς</td></tr>
